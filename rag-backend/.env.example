APP_ENV=local
DATABASE_URL=sqlite:///./data/rag.sqlite
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=rag-ingestion
RAG_PYTHON=
RAG_PYTHON_WINDOWS=
LOCAL_MODEL_API_BASE_URL=http://localhost:9000
LOCAL_MODEL_API_PORT=9000
EMBEDDING_PROVIDER=api
EMBEDDING_API_BASE_URL=http://localhost:9000
EMBEDDING_API_PATH=/v1/embeddings
EMBEDDING_API_KEY=
MINIMAX_API_KEY=
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32
RERANK_API_BASE_URL=http://localhost:9000
RERANK_API_PATH=/v1/rerank
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_UPLOAD_MB=50
MAX_UPLOAD_BATCH_MB=100
ALLOWED_EXTENSIONS=.txt,.md,.pdf
